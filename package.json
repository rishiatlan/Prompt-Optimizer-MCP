{
  "name": "pcp-engine",
  "version": "5.3.2",
  "type": "module",
  "description": "PCP — the prompt quality engine. Deterministic scoring, compilation, cost estimation & governance for AI prompts. Zero LLM calls.",
  "main": "dist/src/api.js",
  "types": "dist/src/api.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/api.d.ts",
      "import": "./dist/src/api.js"
    },
    "./server": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./validate": {
      "types": "./dist/src/validate.d.ts",
      "import": "./dist/src/validate.js"
    }
  },
  "bin": {
    "pcp-engine": "bin/cli.js",
    "prompt-lint": "bin/lint.js",
    "pcp": "bin/pcp.js"
  },
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "bin",
    "benchmarks",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "test": "node --test dist/test/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "pcp-engine",
    "prompt-governance",
    "prompt-optimization",
    "prompt-engineering",
    "token-cost",
    "llm",
    "anthropic",
    "ai",
    "cost-reduction",
    "context-compression",
    "model-routing",
    "freemium",
    "prompt-scoring",
    "multi-llm",
    "prompt-linter",
    "lint",
    "pcp",
    "cli",
    "prompt-quality",
    "audit-trail",
    "policy-enforcement"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rishi-banerjee1/prompt-control-plane.git"
  },
  "homepage": "https://getpcp.site/",
  "bugs": {
    "url": "https://github.com/rishi-banerjee1/prompt-control-plane/issues"
  },
  "mcpName": "io.github.rishi-banerjee1/pcp-engine",
  "author": "Rishi Banerjee",
  "license": "Elastic-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "fast-glob": "^3.3.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
